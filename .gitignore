# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# Virtual environments
.venv/
.env/

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Editor / IDE
.idea/
.vscode/

# Coder session scaffolding
.coder-session/

# Claude Code: ignore local/temporary state (worktrees created by
# isolation: worktree, local settings, caches) but TRACK the shared,
# portable tooling so agents/commands/workflows/skills travel with the repo.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/workflows/
!.claude/skills/

# OS metadata
.DS_Store
Thumbs.db
.gitnexus
