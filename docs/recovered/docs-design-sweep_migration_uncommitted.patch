+* Post-estimation inference helpers
+
+The following ManifoldGMM helpers have landed in Emu-GMM v1 and are
+re-exported from the top-level =emu_gmm= namespace. Each is a single
+functional call against an existing =measure= / =covariance= / =model=
+trio; none requires holding a driver object.
+
+** =j_test= --- zero-parameter J-test at a hypothesised \(\theta_0\)
+
+#+BEGIN_SRC python
+from emu_gmm import j_test  # -> JTestResult
+
+jt = j_test(
+    measure,
+    covariance,
+    model=psi,
+    theta_null=theta_null,        # any ParamsLike
+)
+# jt.J_stat (0-d), jt.J_pvalue (0-d), jt.J_dof (static int),
+# jt.V_X (haliax.NamedArray).
+#+END_SRC
+
+** =k_statistic= --- Kleibergen weak-IV-robust \(K/S/J\) decomposition
+
+#+BEGIN_SRC python
+from emu_gmm import k_statistic  # -> KStatisticResult
+
+ks = k_statistic(
+    result,                       # or a hypothesised theta_null
+    measure,
+    covariance,
+    model=psi,
+)
+# ks.K, ks.S, ks.J (0-d JAX arrays) with df_K / df_S / df_J and
+# p-values. The K-statistic uses the orthogonalised D-tilde Jacobian so
+# the chi^2_p limit holds regardless of identification strength.
+#+END_SRC
+
+** =moment_wild_bootstrap= --- refit-free cluster-wild Rademacher bootstrap
+
+#+BEGIN_SRC python
+import jax
+from emu_gmm import moment_wild_bootstrap  # -> WildBootstrapResult
+
+wb = moment_wild_bootstrap(
+    model=psi,
+    theta_hat=result.theta_hat,
+    measure=measure,              # EmpiricalMeasure
+    covariance=covariance,        # ClusteredCovariance
+    n_boot=999,
+    key=jax.random.PRNGKey(0),
+    V=result.V_X,                 # reuse the analytic V to keep calibration consistent
+)
+# wb.J_boot (shape (n_boot,)), wb.p_value (0-d), wb.J_observed (0-d).
+# Refit-free: L = chol(V_X(theta_hat)) is fixed across replicates.
+#+END_SRC
+
+** =cluster_bootstrap= --- refit-based cluster bootstrap
+
+#+BEGIN_SRC python
+import jax
+from emu_gmm import cluster_bootstrap  # -> ClusterBootstrapResult
+
+cb = cluster_bootstrap(
+    model=psi,
+    theta_init=Theta(theta=jnp.zeros(M)),
+    measure=measure,              # EmpiricalMeasure
+    covariance=covariance,        # ClusteredCovariance
+    n_boot=200,
+    key=jax.random.PRNGKey(0),
+)
+# cb.theta_boot (haliax.NamedArray, axes (bootstrap, parameters)),
+# cb.J_boot ((n_boot,)), cb.convergence (numpy bool array),
+# cb.param_names (tuple[str, ...]).
+#+END_SRC
+
+** =numerics.ridge_inverse= --- adaptive ridge inverse helper
+
+#+BEGIN_SRC python
+from emu_gmm import ridge_inverse
+
+M_inv, info = ridge_inverse(M, target_condition=1.0e6)
+# M_inv: haliax.NamedArray inverse of the ridge-stabilised matrix.
+# info: dict with 'tau', 'kappa_before', 'kappa_after', 'binding'.
+#+END_SRC
+
+** =IteratedWeighting= --- legacy two-step / k-step weighting
+
+#+BEGIN_SRC python
+from emu_gmm import IteratedWeighting
+
+result = estimate(
+    model=psi,
+    measure=measure,
+    covariance=covariance,
+    weighting=IteratedWeighting(weighting_iterations=10, weighting_tol=1e-6),
+    theta_init=Theta(theta=jnp.zeros(M)),
+)
+# Falls back to CU behaviour when called outside estimate(); the
+# iterated outer loop only runs inside the estimator driver.
+#+END_SRC
+
